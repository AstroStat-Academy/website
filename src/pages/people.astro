---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our People"
  description="The team behind AstroStat Academy."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <h1 class="text-4xl font-bold mb-4">Our People</h1>
    <p class="text-slate-300 text-lg mb-6">
      Our team of astronomers and statisticians will be listed here soon.
    </p>
    <p class="text-slate-500 text-sm">
      In the meantime, reach us at
      <a href="mailto:info@astrostat.academy" class="text-accent-teal hover:underline">info@astrostat.academy</a>.
    </p>
  </div>
</BaseLayout>
