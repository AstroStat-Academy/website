---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our People"
  description="The team behind AstroStat Academy."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <div class="rounded-3xl border border-ink/10 bg-gradient-to-br from-white/85 via-bone to-blue/10 p-8 shadow-[0_18px_50px_rgba(4,101,173,0.10)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-blue/10">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-blue">People</p>
    <h1 class="text-4xl font-bold mb-4 text-ink dark:text-bone">Our People</h1>
    <p class="text-ink/70 text-lg mb-6 dark:text-bone/70">
      Our team of astronomers and statisticians will be listed here soon.
    </p>
    <p class="text-ink/50 text-sm dark:text-bone/50">
      In the meantime, reach us at
      <a href="mailto:info@astrostat.academy" class="text-blue hover:underline">info@astrostat.academy</a>.
    </p>
    </div>
  </div>
</BaseLayout>
