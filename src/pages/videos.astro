---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Video Lectures" description="On-demand video lectures from AstroStat Academy schools — coming soon.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <p class="text-5xl mb-6">🎬</p>
    <h1 class="text-4xl font-bold mb-4">Video Lectures</h1>
    <p class="text-slate-300 text-lg mb-6">
      On-demand recordings from our schools, covering Bayesian inference, machine learning,
      time-series analysis, and more — coming soon.
    </p>
    <p class="text-slate-500 text-sm">
      In the meantime, <a href="/schools" class="text-accent-teal hover:underline">browse our upcoming schools</a>.
    </p>
  </div>
</BaseLayout>
