---
import BaseLayout from '../layouts/BaseLayout.astro';
import CodeRain from '../components/effects/CodeRain';
---

<BaseLayout
  title="Home"
  description="AstroStat Academy — intensive statistics schools and workshops for the astronomical community."
>
  <!-- Hero -->
  <section class="relative py-28 md:py-40 px-4 text-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-800 to-navy-900 -z-20" />
    <CodeRain client:only="react" />
    <div class="max-w-3xl mx-auto">
      <p class="text-accent-teal text-sm font-semibold tracking-widest uppercase mb-4">
        Statistics for the Universe
      </p>
      <h1 class="text-5xl md:text-7xl font-bold leading-tight mb-12">
        AstroStat<br />
        <span class="text-accent-teal">Academy</span>
      </h1>
      <!-- Activity tiles -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto">
        <a
          href="/schools"
          class="bg-navy-800/80 border border-accent-teal/40 rounded-xl p-6 flex flex-col items-center gap-2 hover:border-accent-teal hover:bg-navy-800 transition-colors group"
        >
          <span class="text-3xl">🎓</span>
          <span class="font-semibold text-white group-hover:text-accent-teal transition-colors">Schools</span>
        </a>
        <a
          href="/hackatons"
          class="bg-navy-800/80 border border-white/10 rounded-xl p-6 flex flex-col items-center gap-2 hover:border-white/30 hover:bg-navy-800 transition-colors group"
        >
          <span class="text-3xl">⚡</span>
          <span class="font-semibold text-slate-400 group-hover:text-white transition-colors">Hackatons</span>
          <span class="text-xs text-slate-600 uppercase tracking-wider">Coming soon</span>
        </a>
        <a
          href="/consulting"
          class="bg-navy-800/80 border border-white/10 rounded-xl p-6 flex flex-col items-center gap-2 hover:border-white/30 hover:bg-navy-800 transition-colors group"
        >
          <span class="text-3xl">📊</span>
          <span class="font-semibold text-slate-400 group-hover:text-white transition-colors">Consulting</span>
          <span class="text-xs text-slate-600 uppercase tracking-wider">Coming soon</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4 text-slate-100">Our Mission</h2>
      <p class="text-slate-300 text-lg leading-relaxed">
        Astronomy generates petabytes of data. Making sense of it requires rigorous statistical
        thinking. AstroStat Academy bridges the gap between modern statistics and observational
        astronomy through hands-on, expert-led schools for PhD students and early-career researchers.
      </p>
    </div>
  </section>

  <!-- Goals -->
  <section class="py-16 px-4 bg-navy-800/40">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4 text-slate-100">Our Goals</h2>
      <p class="text-slate-300 text-lg leading-relaxed">
        We aim to raise statistical literacy across the astronomical community — equipping
        researchers with the modern probabilistic and machine-learning tools they need to
        extract knowledge from today's large surveys and tomorrow's petabyte telescopes.
      </p>
    </div>
  </section>

  <!-- People CTA -->
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <a
        href="/people"
        class="text-accent-teal hover:text-teal-300 text-lg font-medium transition-colors"
      >
        Meet our people →
      </a>
    </div>
  </section>
</BaseLayout>
