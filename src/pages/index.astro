---
import BaseLayout from '../layouts/BaseLayout.astro';
import TitleDot from '../components/effects/TitleDot';
import Typewriter from '../components/effects/Typewriter';

const taglines = [
  'Advanced statistics. Taught and applied.',
  'High-level statistical training and expert consulting.',
  'The statistics support you need. Taught and delivered.',
];
---

<BaseLayout
  title="Home"
  description="AstroStat Academy — intensive statistics schools and workshops for the astronomical community."
>
  <!-- Hero: full viewport below sticky nav (nav = h-16 = 4rem), title centered -->
  <section class="relative h-[calc(100vh-4rem)] flex items-center justify-center px-4 text-center overflow-hidden">
    <div class="relative z-10 w-full max-w-3xl mx-auto -mt-16">
      <p class="text-ink/55 text-sm font-mono tracking-wider uppercase mb-4 min-h-[1.5em] dark:text-bone/55">
        <Typewriter phrases={taglines} client:load />
      </p>
      <TitleDot client:load />
      <p class="text-xs font-mono tracking-widest mt-2" style="color: #0465ad;">Take control of your statistics.</p>
    </div>
  </section>

  <!-- Activities: hexagon honeycomb
       Layout: pointy-top hexes, H=200px W≈173px, 2 top + 1 bottom-center
       Vertical row spacing = 3H/4 = 150px (honeycomb tiling)
       On mobile: scale to 88% so 346px visual → ~305px, fits 320px+ screens -->
  <section class="py-24 text-center overflow-x-hidden">
    <div class="scale-[0.88] sm:scale-100 origin-top -mb-[42px] sm:mb-0"
         style="position: relative; width: 346px; height: 350px; margin: 0 auto;">

      <!-- Schools: top-left -->
      <a href="/schools" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 0; top: 0; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: linear-gradient(145deg, rgba(18,18,18,0.96), rgba(0,0,0,0.86)); border: 1px solid rgba(4,101,173,0.35); filter: drop-shadow(0 12px 22px rgba(4,101,173,0.16));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: rgba(251,246,236,0.20); line-height: 1;">01</span>
          <span class="text-sm font-semibold text-bone transition-colors">Schools</span>
        </div>
      </a>

      <!-- Hackatons: top-right -->
      <a href="/hackatons" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 173px; top: 0; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: linear-gradient(145deg, rgba(18,18,18,0.82), rgba(0,0,0,0.74)); border: 1px solid rgba(251,246,236,0.14); filter: drop-shadow(0 10px 18px rgba(0,0,0,0.18));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: rgba(251,246,236,0.14); line-height: 1;">02</span>
          <span class="text-sm font-semibold text-bone/85 transition-colors">Hackatons</span>
          <span class="rounded-full bg-bone/10 px-2 py-0.5 text-xs text-bone/70 uppercase tracking-wider">Soon</span>
        </div>
      </a>

      <!-- Consulting: bottom-center -->
      <a href="/consulting" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 87px; top: 150px; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: linear-gradient(145deg, rgba(18,18,18,0.82), rgba(0,0,0,0.74)); border: 1px solid rgba(251,246,236,0.14); filter: drop-shadow(0 10px 18px rgba(0,0,0,0.18));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: rgba(251,246,236,0.14); line-height: 1;">03</span>
          <span class="text-sm font-semibold text-bone/85 transition-colors">Consulting</span>
          <span class="rounded-full bg-bone/10 px-2 py-0.5 text-xs text-bone/70 uppercase tracking-wider">Soon</span>
        </div>
      </a>

    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto grid gap-6 md:grid-cols-2">
      <div class="rounded-3xl border border-ink/10 bg-gradient-to-br from-white/80 via-bone to-blue/10 p-8 shadow-[0_18px_50px_rgba(4,101,173,0.10)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-blue/10">
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-blue">01 · Mission</p>
        <h2 class="text-2xl font-bold mb-4 text-ink dark:text-bone">Our Mission</h2>
        <p class="text-ink/70 text-lg leading-relaxed dark:text-bone/70">
          Astronomy generates petabytes of data. Making sense of it requires rigorous statistical
          thinking. AstroStat Academy bridges the gap between modern statistics and observational
          astronomy through hands-on, expert-led schools for PhD students and early-career researchers.
        </p>
      </div>
      <div class="rounded-3xl border border-ink/10 bg-gradient-to-br from-white/80 via-bone to-red/10 p-8 shadow-[0_18px_50px_rgba(140,5,39,0.08)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-red/10">
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-red">02 · Goals</p>
        <h2 class="text-2xl font-bold mb-4 text-ink dark:text-bone">Our Goals</h2>
        <p class="text-ink/70 text-lg leading-relaxed dark:text-bone/70">
          We aim to raise statistical literacy across the astronomical community — equipping
          researchers with the modern probabilistic and machine-learning tools they need to
          extract knowledge from today's large surveys and tomorrow's petabyte telescopes.
        </p>
      </div>
    </div>
  </section>

  <!-- People CTA -->
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <a
        href="/people"
        class="inline-flex rounded-full border border-blue/30 bg-ink/85 px-6 py-3 text-lg font-semibold text-bone shadow-[0_12px_30px_rgba(4,101,173,0.18)] transition-all hover:-translate-y-0.5 hover:border-blue/50 hover:bg-blue hover:text-bone"
      >
        Meet our people →
      </a>
    </div>
  </section>
</BaseLayout>
