---
import BaseLayout from '../layouts/BaseLayout.astro';
import TitleDot from '../components/effects/TitleDot';
import Typewriter from '../components/effects/Typewriter';

const taglines = [
  'Advanced statistics. Taught and applied.',
  'Where rigorous statistics meets real science.',
  'Master the methods. Solve the problems.',
  'Statistical expertise — in the classroom and in the field.',
  'From first principles to your toughest analysis.',
  'Train deep. Consult smart.',
  'Advanced statistical training and expert consulting.',
  'The statistics you need. Taught and delivered.',
  'Precision statistics for complex problems.',
  'Learn it. Apply it. Get it done.',
];
---

<BaseLayout
  title="Home"
  description="AstroStat Academy — intensive statistics schools and workshops for the astronomical community."
  showGalaxy={false}
>
  <!-- Hero: full viewport below sticky nav (nav = h-16 = 4rem), title centered -->
  <section class="relative h-[calc(100vh-4rem)] flex items-center justify-center px-4 text-center overflow-hidden">
    <div class="relative z-10 max-w-3xl mx-auto -mt-16">
      <p class="text-bone text-sm font-mono tracking-wider uppercase mb-4 min-h-[1.5em]">
        <Typewriter phrases={taglines} client:load />
      </p>
      <TitleDot client:load />
      <p class="text-xs font-mono tracking-widest mt-2" style="color: #0465ad;">Take control of your statistics.</p>
    </div>
  </section>

  <!-- Activities: hexagon honeycomb
       Layout: pointy-top hexes, H=200px W≈173px, 2 top + 1 bottom-center
       Vertical row spacing = 3H/4 = 150px (honeycomb tiling)
       On mobile: scale to 88% so 346px visual → ~305px, fits 320px+ screens -->
  <section class="py-24 text-center overflow-x-hidden">
    <div class="scale-[0.88] sm:scale-100 origin-top -mb-[42px] sm:mb-0"
         style="position: relative; width: 346px; height: 350px; margin: 0 auto;">

      <!-- Schools: top-left -->
      <a href="/schools" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 0; top: 0; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: var(--color-hex-active); filter: drop-shadow(0 0 5px var(--color-accent-45));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: var(--color-accent-20); line-height: 1;">01</span>
          <span class="text-sm font-semibold text-white group-hover:text-bone transition-colors">Schools</span>
        </div>
      </a>

      <!-- Hackatons: top-right -->
      <a href="/hackatons" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 173px; top: 0; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: var(--color-hex-inactive); filter: drop-shadow(0 0 2px var(--color-subtle-white));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: rgba(255,255,255,0.07); line-height: 1;">02</span>
          <span class="text-sm font-semibold text-slate-400 group-hover:text-white transition-colors">Hackatons</span>
          <span class="text-xs text-slate-600 uppercase tracking-wider">Soon</span>
        </div>
      </a>

      <!-- Consulting: bottom-center -->
      <a href="/consulting" class="group absolute transition-transform duration-300 hover:scale-[1.05]"
         style="left: 87px; top: 150px; width: 173px; height: 200px; display: flex; align-items: center; justify-content: center;">
        <div class="absolute"
             style="inset: 3px; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); background: var(--color-hex-inactive); filter: drop-shadow(0 0 2px var(--color-subtle-white));"></div>
        <div class="relative flex flex-col items-center gap-1" style="z-index: 10;">
          <span class="font-mono font-bold" style="font-size: 2rem; color: rgba(255,255,255,0.07); line-height: 1;">03</span>
          <span class="text-sm font-semibold text-slate-400 group-hover:text-white transition-colors">Consulting</span>
          <span class="text-xs text-slate-600 uppercase tracking-wider">Soon</span>
        </div>
      </a>

    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4 text-slate-100">Our Mission</h2>
      <p class="text-slate-300 text-lg leading-relaxed">
        Astronomy generates petabytes of data. Making sense of it requires rigorous statistical
        thinking. AstroStat Academy bridges the gap between modern statistics and observational
        astronomy through hands-on, expert-led schools for PhD students and early-career researchers.
      </p>
    </div>
  </section>

  <!-- Goals -->
  <section class="py-16 px-4 bg-ink/40">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4 text-slate-100">Our Goals</h2>
      <p class="text-slate-300 text-lg leading-relaxed">
        We aim to raise statistical literacy across the astronomical community — equipping
        researchers with the modern probabilistic and machine-learning tools they need to
        extract knowledge from today's large surveys and tomorrow's petabyte telescopes.
      </p>
    </div>
  </section>

  <!-- People CTA -->
  <section class="py-16 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <a
        href="/people"
        class="text-bone hover:text-bone text-lg font-medium transition-colors"
      >
        Meet our people →
      </a>
    </div>
  </section>
</BaseLayout>
