---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AttendanceChart from '../../components/charts/AttendanceChart';
import ApplicationForm from '../../components/forms/ApplicationForm';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const schools = await getCollection('schools');
  return schools.map((school) => ({
    params: { slug: school.slug },
    props: {
      school,
      // Pass all schools for the attendance chart context
      allSchools: schools
        .filter((s) => s.data.attendees !== undefined)
        .map((s) => ({
          title: s.data.title,
          date: s.data.date.toISOString(),
          attendees: s.data.attendees as number,
        })),
    },
  }));
};

const { school, allSchools } = Astro.props;
const { Content } = await school.render();
const { title, date, endDate, location, description, lecturers, topics, attendees, applicationUrl } =
  school.data;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const dateRange = endDate
  ? `${formatDate(date)} – ${formatDate(endDate)}`
  : formatDate(date);

const isPast = (endDate ?? date) < new Date();
---

<BaseLayout title={title} description={description}>
  <!-- Page header -->
  <div class="border-b border-ink/10 bg-gradient-to-br from-white/80 via-bone to-blue/10 dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-blue/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
      <a href="/schools" class="inline-flex rounded-full border border-blue/20 bg-white/70 px-3 py-1.5 text-blue text-sm font-medium hover:bg-blue hover:text-bone transition-colors mb-6">
        ← All schools
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span
          class={`text-xs font-semibold px-2.5 py-1 rounded-full ${
            isPast
              ? 'bg-ink/5 text-ink/55 border border-ink/10'
              : 'bg-blue/10 text-blue border border-blue/20'
          }`}
        >
          {isPast ? 'Past' : 'Upcoming'}
        </span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight text-ink dark:text-bone">{title}</h1>
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-ink/65 text-sm dark:text-bone/65">
        <span>{dateRange}</span>
        <span>{location}</span>
        {attendees && <span>{attendees} attendees</span>}
      </div>
      {applicationUrl && !isPast && (
        <a
          href={applicationUrl}
          class="mt-6 inline-block rounded-full bg-blue px-6 py-2.5 font-semibold text-bone shadow-[0_12px_30px_rgba(4,101,173,0.20)] transition-all hover:-translate-y-0.5 hover:bg-blue/90"
        >
          Apply Now
        </a>
      )}
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 space-y-14">
    <!-- Markdown content -->
    <section class="prose prose-lg max-w-none prose-headings:text-ink prose-headings:font-bold prose-p:text-ink/75 prose-li:text-ink/75 prose-a:text-blue prose-strong:text-ink dark:prose-headings:text-bone dark:prose-p:text-bone/75 dark:prose-li:text-bone/75 dark:prose-strong:text-bone">
      <Content />
    </section>

    <!-- Lecturers -->
    {lecturers.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold mb-5 text-ink dark:text-bone">Lecturers</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {lecturers.map((l) => (
            <div class="rounded-2xl border border-ink/10 bg-gradient-to-br from-white/85 via-bone to-blue/5 p-4 shadow-[0_12px_30px_rgba(4,101,173,0.06)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-blue/10">
              {l.url ? (
                <a href={l.url} class="font-semibold text-ink hover:text-blue transition-colors dark:text-bone dark:hover:text-bone" target="_blank" rel="noopener noreferrer">
                  {l.name}
                </a>
              ) : (
                <p class="font-semibold text-ink dark:text-bone">{l.name}</p>
              )}
              {l.affiliation && <p class="text-ink/55 text-sm mt-0.5 dark:text-bone/55">{l.affiliation}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Topics -->
    {topics.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold mb-5 text-ink dark:text-bone">Topics</h2>
        <div class="flex flex-wrap gap-2">
          {topics.map((topic) => (
            <span class="bg-white/70 border border-ink/10 rounded-full px-4 py-1.5 text-sm text-ink/65 dark:border-white/10 dark:bg-white/10 dark:text-bone/65">
              {topic}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- Attendance chart (only if data exists) -->
    {allSchools.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold mb-5 text-ink dark:text-bone">Attendance History</h2>
        <AttendanceChart
          schools={allSchools}
          highlightTitle={title}
          client:only="react"
        />
        <p class="text-ink/50 text-sm mt-2 dark:text-bone/50">
          Highlighted bar = this school. All attendee counts are approximate.
        </p>
      </section>
    )}

    <!-- Interest form -->
    <section>
      <h2 class="text-2xl font-bold mb-2 text-ink dark:text-bone">Express Interest</h2>
      <p class="text-ink/60 mb-5 text-sm dark:text-bone/60">
        {isPast
          ? 'Interested in future editions? Leave your details and we\'ll notify you.'
          : 'Not ready to apply? Leave your contact details and we\'ll keep you posted.'}
      </p>
      <ApplicationForm schoolTitle={title} client:load />
    </section>
  </div>
</BaseLayout>
