---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Hackatons"
  description="AstroStat Academy Hackatons — coming soon."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <h1 class="text-4xl font-bold mb-4">Hackatons</h1>
    <p class="text-slate-300 text-lg mb-6">
      Our first hackaton is in the works. Stay tuned for details.
    </p>
    <p class="text-slate-500 text-sm">
      Want to get involved?
      <a href="mailto:info@astrostat.academy" class="text-bone hover:underline">
        Get in touch
      </a>.
    </p>
  </div>
</BaseLayout>
