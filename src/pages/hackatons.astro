---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Hackatons"
  description="AstroStat Academy Hackatons — coming soon."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <div class="rounded-3xl border border-ink/10 bg-gradient-to-br from-white/85 via-bone to-teal/10 p-8 shadow-[0_18px_50px_rgba(0,140,140,0.08)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-teal/10">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-teal">Hackatons</p>
    <h1 class="text-4xl font-bold mb-4 text-ink dark:text-bone">Hackatons</h1>
    <p class="text-ink/70 text-lg mb-6 dark:text-bone/70">
      Our first hackaton is in the works. Stay tuned for details.
    </p>
    <p class="text-ink/50 text-sm dark:text-bone/50">
      Want to get involved?
      <a href="mailto:info@astrostat.academy" class="text-blue hover:underline">
        Get in touch
      </a>.
    </p>
    </div>
  </div>
</BaseLayout>
