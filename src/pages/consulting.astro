---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Consulting" description="Statistical consulting for research groups and institutions — AstroStat Academy.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-32 text-center">
    <div class="rounded-3xl border border-ink/10 bg-gradient-to-br from-white/85 via-bone to-red/10 p-8 shadow-[0_18px_50px_rgba(140,5,39,0.08)] dark:border-white/10 dark:from-white/10 dark:via-ink dark:to-red/10">
    <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-red">Consulting</p>
    <h1 class="text-4xl font-bold mb-4 text-ink dark:text-bone">Enterprise Consulting</h1>
    <p class="text-ink/70 text-lg mb-6 dark:text-bone/70">
      Tailored statistical consulting for research groups, institutes, and space agencies.
      We help teams design analyses, choose models, and interpret results — coming soon.
    </p>
    <p class="text-ink/50 text-sm dark:text-bone/50">
      Interested in working with us?
      <a href="mailto:consulting@astrostat.academy" class="text-blue hover:underline">
        Get in touch
      </a>.
    </p>
    </div>
  </div>
</BaseLayout>
