---
import ThemeToggle from './ThemeToggle';

const navLinks = [
  { href: '/schools', label: 'Schools' },
  { href: '/hackatons', label: 'Hackatons' },
  { href: '/consulting', label: 'Consulting' },
];
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 px-3 py-3">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14 rounded-full border border-ink/10 bg-bone/85 backdrop-blur-md shadow-[0_12px_40px_rgba(4,101,173,0.10)] dark:border-white/10 dark:bg-ink/90 dark:shadow-[0_12px_40px_rgba(4,101,173,0.18)]">
    <a href="/" class="text-lg font-bold tracking-tight text-ink hover:text-blue transition-colors dark:text-bone dark:hover:text-bone">
      AstroStat Academy
    </a>
    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`rounded-full px-3 py-1.5 text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href)
                ? 'bg-blue text-bone shadow-sm'
                : 'text-ink/65 hover:bg-blue/10 hover:text-blue dark:text-bone/60 dark:hover:bg-bone/10 dark:hover:text-bone'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li aria-hidden="true" class="h-4 w-px bg-ink/15 dark:bg-white/20" />
      <li>
        <ThemeToggle client:load />
      </li>
      <li aria-hidden="true" class="h-4 w-px bg-ink/15 dark:bg-white/20" />
      <li>
        <a
          href="/people"
          class={`rounded-full px-3 py-1.5 text-sm font-medium transition-colors ${
            currentPath.startsWith('/people')
              ? 'bg-blue text-bone shadow-sm'
              : 'text-ink/65 hover:bg-blue/10 hover:text-blue dark:text-bone/60 dark:hover:bg-bone/10 dark:hover:text-bone'
          }`}
        >
          People
        </a>
      </li>
    </ul>
    <!-- Mobile -->
    <div class="md:hidden flex gap-2">
      {navLinks.map(link => (
        <a href={link.href} class="rounded-full px-2 py-1 text-ink/65 hover:bg-blue/10 hover:text-blue text-xs transition-colors dark:text-bone/60 dark:hover:bg-bone/10 dark:hover:text-bone">
          {link.label}
        </a>
      ))}
      <ThemeToggle client:load />
      <a href="/people" class="rounded-full px-2 py-1 text-ink/65 hover:bg-blue/10 hover:text-blue text-xs transition-colors dark:text-bone/60 dark:hover:bg-bone/10 dark:hover:text-bone">People</a>
    </div>
  </div>
</nav>
