---
const navLinks = [
  { href: '/schools', label: 'Schools' },
  { href: '/hackatons', label: 'Hackatons' },
  { href: '/consulting', label: 'Consulting' },
];
const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-base/95 backdrop-blur-sm border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <a href="/" class="text-lg font-bold tracking-tight text-accent hover:text-accent transition-colors">
      AstroStat Academy
    </a>
    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href)
                ? 'text-white'
                : 'text-slate-400 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li aria-hidden="true" class="h-4 w-px bg-white/20" />
      <li>
        <a
          href="/people"
          class={`text-sm font-medium transition-colors ${
            currentPath.startsWith('/people')
              ? 'text-white'
              : 'text-slate-400 hover:text-white'
          }`}
        >
          People
        </a>
      </li>
    </ul>
    <!-- Mobile -->
    <div class="md:hidden flex gap-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-slate-400 hover:text-white text-xs transition-colors">
          {link.label}
        </a>
      ))}
      <a href="/people" class="text-slate-400 hover:text-white text-xs transition-colors">People</a>
    </div>
  </div>
</nav>
